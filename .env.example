# Copy to .env.local and populate for local development.
# Never commit .env.local — it's in .gitignore.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required server-side for the Stripe webhook (and any other route that needs to
# bypass RLS on behalf of a trusted external service).
SUPABASE_SERVICE_ROLE_KEY=

# Claude
ANTHROPIC_API_KEY=

# Stripe — billing (Phase 4)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs from the Stripe Dashboard — one per paid plan slug
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# Public origin used to construct Stripe return URLs
# (e.g. https://commandpost.app in production, http://localhost:3000 locally)
NEXT_PUBLIC_APP_URL=http://localhost:3000
