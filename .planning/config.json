{
  "_doc": "Nightwork orchestration config. Spec-required Nightwork extensions live under workflow.* alongside GSD's own fields. GSD ignores unknown keys at read time; the Nightwork orchestrator commands (/nightwork-plan-review, /nightwork-qa, /nightwork-end-to-end-test) read these to know when to auto-invoke.",
  "model_profile": "quality",
  "mode": "interactive",
  "granularity": "standard",
  "commit_docs": false,
  "search_gitignored": true,
  "context_window": 200000,
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist_validation": true,
    "ai_integration_phase": true,
    "ui_phase": true,
    "ui_safety_gate": true,
    "code_review": true,
    "code_review_depth": "standard",
    "discuss_mode": "assumptions",
    "skip_discuss": false,
    "research_before_questions": true,
    "use_worktrees": false,
    "auto_advance": false,
    "node_repair": true,
    "node_repair_budget": 2,
    "subagent_timeout": 600000,
    "security_enforcement": true,
    "security_asvs_level": 2,
    "security_block_on": "high",
    "post_planning_gaps": true,
    "post_plan_hooks": ["nightwork-plan-review"],
    "post_execute_hooks": ["nightwork-qa"],
    "pre_ship_hooks": ["nightwork-qa", "nightwork-end-to-end-test"],
    "qa_gate": true,
    "plan_gate": true,
    "context_coverage_gate": true,
    "drift_action": "auto-remap",
    "acceptance_criteria_required": true
  },
  "git": {
    "branching_strategy": "phase",
    "base_branch": "main",
    "phase_branch_template": "phase/{phase}-{slug}"
  },
  "parallelization": {
    "enabled": true,
    "plan_level": true,
    "task_level": false,
    "max_concurrent_agents": 3,
    "min_plans_for_parallel": 2
  },
  "gates": {
    "confirm_project": true,
    "confirm_phases": true,
    "confirm_roadmap": true,
    "confirm_breakdown": true,
    "confirm_plan": true,
    "execute_next_plan": true,
    "issues_review": true,
    "confirm_transition": true
  },
  "safety": {
    "always_confirm_destructive": true,
    "always_confirm_external_services": true
  },
  "hooks": {
    "context_warnings": true
  },
  "features": {
    "thinking_partner": true,
    "global_learnings": false
  },
  "intel": {
    "enabled": false
  },
  "agent_skills": {
    "gsd-planner": ["search-first", "api-design", "backend-patterns", "postgres-patterns", "deployment-patterns"],
    "gsd-executor": ["search-first", "api-design", "backend-patterns", "postgres-patterns"],
    "gsd-code-reviewer": ["security-review"]
  },
  "claude_md_path": "./CLAUDE.md",
  "nightwork": {
    "tenant_id_ross_built": "RossBuilt is Tenant 1 — pre-launch, test data only",
    "reference_job": "Drummond",
    "scale_target": "100k tenants",
    "design_philosophy_path": ".planning/design/PHILOSOPHY.md",
    "design_prototypes_path": ".planning/design/prototypes/",
    "qa_runs_path": ".planning/qa-runs/",
    "plan_reviews_path": ".planning/plan-reviews/",
    "propagate_runs_path": ".planning/propagate/",
    "e2e_runs_path": ".planning/e2e-runs/",
    "design_checks_path": ".planning/design-checks/",
    "custodian_runs_path": ".planning/custodian-runs/",
    "audits_path": ".planning/audits/"
  }
}
